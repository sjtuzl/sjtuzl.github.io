source "https://rubygems.org"

# Classic GitHub Pages ("Deploy from a branch") builds with the github-pages
# gem, which pins a known-good Jekyll + safelisted plugins. Our plugins
# (jekyll-paginate, jekyll-feed, jekyll-sitemap) are all safelisted.
gem "github-pages", group: :jekyll_plugins

# Ruby 3.4+ no longer bundles these (only needed for local `jekyll serve`).
gem "webrick"
